{application,collaborative_editor,
    [{modules,
         ['Elixir.CollaborativeEditor.Application',
          'Elixir.CollaborativeEditor.Documents',
          'Elixir.CollaborativeEditor.Documents.Document',
          'Elixir.CollaborativeEditor.Mailer',
          'Elixir.CollaborativeEditor.Presence',
          'Elixir.CollaborativeEditor.Repo',
          'Elixir.CollaborativeEditor.YjsSync',
          'Elixir.CollaborativeEditorWeb',
          'Elixir.CollaborativeEditorWeb.DocumentChannel',
          'Elixir.CollaborativeEditorWeb.DocumentController',
          'Elixir.CollaborativeEditorWeb.DocumentJSON',
          'Elixir.CollaborativeEditorWeb.Endpoint',
          'Elixir.CollaborativeEditorWeb.Gettext',
          'Elixir.CollaborativeEditorWeb.Layouts',
          'Elixir.CollaborativeEditorWeb.PageController',
          'Elixir.CollaborativeEditorWeb.Router',
          'Elixir.CollaborativeEditorWeb.Telemetry',
          'Elixir.CollaborativeEditorWeb.UserSocket',
          'Elixir.Phoenix.Param.CollaborativeEditor.Documents.Document']},
     {compile_env,
         [{collaborative_editor,
              ['Elixir.CollaborativeEditorWeb.Gettext'],
              error}]},
     {optional_applications,[]},
     {applications,
         [kernel,stdlib,elixir,logger,runtime_tools,phoenix,phoenix_ecto,
          ecto_sql,postgrex,phoenix_html,phoenix_live_reload,
          phoenix_live_view,phoenix_live_dashboard,esbuild,tailwind,swoosh,
          hackney,finch,telemetry_metrics,telemetry_poller,gettext,jason,
          plug_cowboy,redix,libcluster,uuid,cors_plug,jwt,bcrypt_elixir]},
     {description,"collaborative_editor"},
     {registered,[]},
     {vsn,"1.0.0"},
     {mod,{'Elixir.CollaborativeEditor.Application',[]}}]}.
